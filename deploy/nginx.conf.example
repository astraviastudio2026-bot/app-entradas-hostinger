# ============================================================
# FLAGS FEST - Configuracion de Nginx para VPS Hostinger
# Copia a /etc/nginx/sites-available/flagsfest y ajusta rutas.
#   ln -s /etc/nginx/sites-available/flagsfest /etc/nginx/sites-enabled/
#   nginx -t && systemctl reload nginx
# HTTPS es OBLIGATORIO (la camara del scanner lo exige):
#   certbot --nginx -d flagsfest.astraviastudio.cloud
# ============================================================

server {
    listen 80;
    server_name flagsfest.astraviastudio.cloud;

    root /var/www/flagsfest/app/frontend/dist;
    index index.html;

    # API -> backend Node en 3001
    location /api {
        proxy_pass http://localhost:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # SPA: cualquier ruta (incluida /ticket/validate/<token>) sirve index.html
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Cache de assets con hash
    location /assets/ {
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # Comprobantes de compra web: 5 MB de archivo + cabeceras multipart
    client_max_body_size 6m;
}

# Notas de seguridad del VPS:
# - MySQL solo en 127.0.0.1 (no exponerlo al exterior).
# - Firewall: solo 80/443/SSH.
# - STORAGE_DIR (PDFs) fuera de este root, con permisos solo para el
#   usuario de la app; los PDFs se sirven via /api/tickets/:id/pdf.
# - Backups: dump diario de MySQL (cron + mysqldump) + STORAGE_DIR.
