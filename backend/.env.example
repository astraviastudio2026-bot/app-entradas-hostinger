# ==========================================
# FLAGS FEST - Backend (.env)
# Copia este archivo a .env y completa los valores
# ==========================================

# Servidor
PORT=3001

# Base de datos MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=entradas_user
DB_PASSWORD=
DB_NAME=entradas_app

# JWT (usa una cadena larga y aleatoria en produccion)
JWT_SECRET=cambia-esto-por-una-clave-larga-y-aleatoria
JWT_EXPIRES_IN=12h

# SMTP (Nodemailer) - si se deja vacio, las ventas se guardan
# igual pero no se envian correos automaticamente
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM="FLAGS FEST <entradas@tudominio.com>"
