# ==========================================
# FLAGS FEST - Backend (.env)
# Copia este archivo a .env y completa los valores
# ==========================================

NODE_ENV=production
PORT=3001

# URL pública de la app (se usa en la URL del QR y en CORS)
APP_URL=https://flagsfest.astraviastudio.cloud

# Base de datos MySQL (local en el VPS)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=flagsfest
DB_PASSWORD=
DB_NAME=flagsfest

# Secretos: genera cada uno con `openssl rand -hex 32`.
# QR_SECRET debe ser DISTINTO del JWT_SECRET. Si se pierde el QR_SECRET,
# ningún QR ya emitido volverá a validar.
JWT_SECRET=
QR_SECRET=

# Carpeta de PDFs, FUERA del webroot público
STORAGE_DIR=/var/www/flagsfest/storage

# SMTP (Resend). Si se deja vacío, las ventas se registran igual y el
# correo queda pendiente (se puede reenviar cuando haya SMTP).
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=
SMTP_FROM="FLAGS FEST <entradas@mail.flagsfest.astraviastudio.cloud>"

# Contraseña del admin que crea `npm run seed` (username: admin).
# Si se omite, el seed genera una aleatoria y la imprime por consola.
ADMIN_SEED_PASSWORD=

# Símbolo de moneda (Ecuador usa USD)
CURRENCY_SYMBOL=$
